package-as: VolumeSliders
enable-nolib-creation: no

move-folders:
  VolumeSliders/VolumeSliders: VolumeSliders

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - local_dev_assets
  - docs
  - GEMINI.md
  - AGENTS.md
  - .agent
  - spec
  - .luarc.json
  - .busted
  - .logs
